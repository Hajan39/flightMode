{
  "name": "flight-mode",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "update": "expo install --fix",
    "ota:preview": "node ./scripts/eas-update-from-changelog.js preview",
    "ota:production": "node ./scripts/eas-update-from-changelog.js production",
    "eas:build:android": "npx eas-cli build --platform android --profile production",
    "deploy:android": "npx eas-cli build --platform android --auto-submit --profile production",
    "eas:submit:android": "npx eas-cli submit --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.33",
    "babel-plugin-react-compiler": "^1.0.0",
    "expo": "~55.0.9",
    "expo-application": "~55.0.14",
    "expo-audio": "~55.0.9",
    "expo-av": "^16.0.8",
    "expo-constants": "~55.0.9",
    "expo-device": "~55.0.15",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-insights": "~55.0.16",
    "expo-linking": "~55.0.9",
    "expo-localization": "~55.0.13",
    "expo-network": "~55.0.13",
    "expo-router": "~55.0.7",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-updates": "~55.0.20",
    "expo-web-browser": "~55.0.10",
    "posthog-react-native": "^4.43.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
